/**
 * Firestore Security Rules for Fish Trading Management System
 * 
 * CORE PHILOSOPHY:
 * Robust Path-Based Ownership.
 * Everything under /users/{userId}/ belongs exclusively to that user.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Comprehensive rule for the user's entire data tree
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Explicit rule for the user document itself
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // SPECIAL RULE: Allow any authenticated user to READ from the demo account for migration
    // Account UID: luJcA2AwKHYdXbeU9GvietyCkeu2
    match /users/luJcA2AwKHYdXbeU9GvietyCkeu2/{allPaths=**} {
      allow read: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
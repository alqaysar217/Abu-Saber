/**
 * Firestore Security Rules for Fish Trading Management System
 * 
 * CORE PHILOSOPHY:
 * Robust Path-Based Ownership.
 * Everything under /users/{userId}/ belongs exclusively to that user.
 * 
 * NOTE: Triggering a fresh redeployment to ensure deep sub-collection 
 * permissions (like expenses) are correctly applied.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Comprehensive rule for the user's root and all nested sub-collections
    // This explicitly covers /users/{userId}, /users/{userId}/campaigns, 
    // /users/{userId}/campaigns/{id}/expenses, etc.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
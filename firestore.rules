/**
 * Firestore Security Rules for Fish Trading Management System
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a robust User-Ownership model.
 * Everything under the path /users/{userId}/ is private to that user.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Match any document under the /users/{userId} hierarchy
    match /users/{userId} {
      // Allow the owner to manage their own user document
      allow read, write: if isOwner(userId);

      // Recursive match for ALL subcollections under the user's path
      // This covers customers, suppliers, campaigns, invoices, purchases, expenses, etc.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
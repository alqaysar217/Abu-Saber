/**
 * Firestore Security Rules for Fish Trading Management System
 * 
 * CORE PHILOSOPHY:
 * Robust Path-Based Ownership.
 * Everything under /users/{userId}/ belongs exclusively to that user.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Simplest and most robust ownership rule:
    // Any document or subcollection under /users/{userId} is accessible only by that userId.
    // Triggering a redeployment with this comment.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}